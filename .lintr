linters: linters_with_defaults(
    line_length_linter(100L),
    object_name_linter(styles = c("snake_case", "SNAKE_CASE", "symbols", "dotted.case")),
    indentation_linter = NULL,
    object_usage_linter = NULL,
    semicolon_linter = NULL,
    commented_code_linter = NULL
  )
encoding: "UTF-8"
exclusions: list("tests/testthat.R", "data-raw",
    "tests/testthat/mock-xera-doi", "tests/testthat/mock-xera-pmid",
    "tests/testthat/mock-crossref", "tests/testthat/mock-openalex",
    "tests/testthat/mock-europepmc", "tests/testthat/mock-ncbi",
    "tests/testthat/mock-datacite", "tests/testthat/mock-preprint",
    "tests/testthat/mock-pmc")
